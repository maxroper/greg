# Copy to .dev.vars for local Pages Functions development with `wrangler pages dev`.
# .dev.vars is gitignored. Never commit real keys.

# --- Stripe (required for checkout) ---
# Get test key from https://dashboard.stripe.com/test/apikeys
# Format: sk_test_<your-secret-key>
STRIPE_SECRET_KEY=

# Webhook signing secret from Stripe Dashboard > Developers > Webhooks
# Format: whsec_<your-signing-secret>
STRIPE_WEBHOOK_SECRET=

# --- Email notifications (optional) ---
# Get a free key from https://resend.com (3,000 emails/month free)
# Without this, form submissions and order alerts only log to the console.
RESEND_API_KEY=

# Where Greg receives notifications.
NOTIFY_TO=gpryor@lifepriority.com

# The "From" address shown on outgoing notification emails. Must be either:
#   1. onboarding@resend.dev   (works immediately, sends only to your Resend account email)
#   2. an address on a domain you've verified in Resend (e.g. noreply@lifepriority.com)
NOTIFY_FROM=Greg's Site <onboarding@resend.dev>

# --- Facebook posts (optional) ---
# Without these the Facebook section uses a static fallback. To pull real posts:
#   1. Create a Meta app at https://developers.facebook.com/apps
#   2. Generate a long-lived Page Access Token for the GregPryor85 page
#      (see README for the exact steps)
#   3. Paste the token here.
FB_PAGE_ID=GregPryor85
FB_PAGE_ACCESS_TOKEN=

# --- Spotify playlists (optional) ---
# Without these the music section uses 4 static placeholder playlists.
# Get keys from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Greg's username (e.g. "gregpryor4" — find at open.spotify.com/user/<username>)
SPOTIFY_USER_ID=
# Optional: pin a specific 4 playlists by ID (comma-separated).
# Without it, we just take the first 4 public playlists.
# SPOTIFY_PLAYLIST_IDS=37i9dQZF1DX...,...,...,...

# --- Google Analytics (optional) ---
# Build-time var: must be prefixed VITE_ so it gets inlined into the client
# bundle. Without it, no GA script loads at all (no cookies, no tracking).
# Get from analytics.google.com -> Admin -> Data Streams -> Web
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Optional ---
# Override the public origin used in Stripe success/cancel URLs.
# PUBLIC_BASE_URL=https://gregpryor.com
