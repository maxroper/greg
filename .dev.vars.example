# Copy to .dev.vars for local Pages Functions development with `wrangler pages dev`.
# .dev.vars is gitignored. Never commit real keys.

# --- Stripe (required for checkout) ---
# Get test key from https://dashboard.stripe.com/test/apikeys
# Format: sk_test_<your-secret-key>
STRIPE_SECRET_KEY=

# Webhook signing secret from Stripe Dashboard > Developers > Webhooks
# Format: whsec_<your-signing-secret>
STRIPE_WEBHOOK_SECRET=

# --- Email notifications (optional) ---
# Get a free key from https://resend.com (3,000 emails/month free)
# Without this, form submissions and order alerts only log to the console.
RESEND_API_KEY=

# Where Greg receives notifications.
NOTIFY_TO=gpryor@lifepriority.com

# The "From" address shown on outgoing notification emails. Must be either:
#   1. onboarding@resend.dev   (works immediately, sends only to your Resend account email)
#   2. an address on a domain you've verified in Resend (e.g. noreply@lifepriority.com)
NOTIFY_FROM=Greg's Site <onboarding@resend.dev>

# --- Optional ---
# Override the public origin used in Stripe success/cancel URLs.
# PUBLIC_BASE_URL=https://gregpryor.com
